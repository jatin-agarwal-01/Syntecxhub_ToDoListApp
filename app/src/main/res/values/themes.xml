<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.ToDoListApp" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/purple_light</item>
        <item name="android:statusBarColor">@color/purple_primary</item>
        <item name="android:windowBackground">@color/bg_screen</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
    </style>

    <style name="TimePickerTheme" parent="Theme.Material3.DayNight.Dialog">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsFloating">true</item>
    </style>

</resources>